{% if framework == "langchain" %}
from ragatouille import RAGPretrainedModel
from langchain_core.retrievers import BaseRetriever
from langchain_core.callbacks import CallbackManagerForRetrieverRun
from langchain_core.documents import Document
from pydantic import ConfigDict
from typing import Any, List


class _ColBERTRetriever(BaseRetriever):
    """LangChain BaseRetriever wrapping RAGatouille ColBERT late-interaction reranker."""

    model_config = ConfigDict(arbitrary_types_allowed=True)

    base_retriever: Any
    rag_model: Any
    top_n: int

    def _get_relevant_documents(
        self,
        query: str,
        *,
        run_manager: CallbackManagerForRetrieverRun,
    ) -> List[Document]:
        docs = self.base_retriever.invoke(query)
        texts = [d.page_content for d in docs]
        if not texts:
            return docs[:self.top_n]
        results = self.rag_model.rerank(query=query, documents=texts, k=self.top_n)
        ranked = {r["content"]: r["score"] for r in results}
        return sorted(
            docs,
            key=lambda d: ranked.get(d.page_content, 0.0),
            reverse=True,
        )[:self.top_n]


def build_reranker(retriever: Any) -> Any:
    rag = RAGPretrainedModel.from_pretrained("{{ reranker.model }}")
    return _ColBERTRetriever(base_retriever=retriever, rag_model=rag, top_n={{ reranker.top_n }})
{% elif framework == "llamaindex" %}
from ragatouille import RAGPretrainedModel
from llama_index.core.postprocessor.types import BaseNodePostprocessor
from llama_index.core.schema import NodeWithScore, QueryBundle
from pydantic import ConfigDict
from typing import Any, List, Optional


class _ColBERTPostprocessor(BaseNodePostprocessor):
    """LlamaIndex NodePostProcessor wrapping RAGatouille ColBERT."""

    model_config = ConfigDict(arbitrary_types_allowed=True)

    rag_model: Any
    top_n: int

    def _postprocess_nodes(
        self,
        nodes: List[NodeWithScore],
        query_bundle: Optional[QueryBundle] = None,
    ) -> List[NodeWithScore]:
        if not nodes or query_bundle is None:
            return nodes[:self.top_n]
        query = query_bundle.query_str
        texts = [n.node.get_content() for n in nodes]
        results = self.rag_model.rerank(query=query, documents=texts, k=self.top_n)
        score_map = {r["content"]: r["score"] for r in results}
        return sorted(
            nodes,
            key=lambda n: score_map.get(n.node.get_content(), 0.0),
            reverse=True,
        )[:self.top_n]


def build_reranker() -> Any:
    rag = RAGPretrainedModel.from_pretrained("{{ reranker.model }}")
    return _ColBERTPostprocessor(rag_model=rag, top_n={{ reranker.top_n }})
{% endif %}
