# ─── Graph State ──────────────────────────────────────────────────────────────
class AgentState(TypedDict):
    query: str
    documents: List[Any]
    generation: str
    contexts: List[str]

# ─── Nodes ────────────────────────────────────────────────────────────────────
def retrieve_node(state: AgentState) -> dict[str, Any]:
    print("--- RETRIEVING ---")
    embedder = build_embedding()
    vectorstore = build_vectordb(embedder)
    retriever = build_retrieval(vectorstore)
    docs = retriever.invoke(state["query"])
    return {"documents": docs}

def generate_node(state: AgentState) -> dict[str, Any]:
    print("--- GENERATING ---")
    llm = build_llm()
    prompt = ChatPromptTemplate.from_template(_PROMPT_TEMPLATE)
    
    docs = state["documents"]
    contexts = [doc.page_content for doc in docs]
    context_str = "\n---\n".join(contexts)
    
    chain = prompt | llm
    response = chain.invoke({"context": context_str, "question": state["query"]})
    answer = response.content if hasattr(response, "content") else str(response)
    
    return {"generation": answer, "contexts": contexts}

# ─── Build Graph ──────────────────────────────────────────────────────────────
def build_agent_graph():
    from langgraph.checkpoint.memory import MemorySaver
    
    workflow = StateGraph(AgentState)
    
    # Define the nodes
    workflow.add_node("retrieve", retrieve_node)
    workflow.add_node("generate", generate_node)
    
    # Build edges
    workflow.set_entry_point("retrieve")
    workflow.add_edge("retrieve", "generate")
    workflow.add_edge("generate", END)
    
    # Add checkpointer for safe thread-based conversation memory
    memory = MemorySaver()
    return workflow.compile(checkpointer=memory)

# ─── Pipeline Entrypoints ─────────────────────────────────────────────────────
def run_pipeline(
    query: str,
    return_contexts: bool = False,
    thread_id: str = "default_thread",
) -> str | tuple[str, list[str]]:
    """Synchronously run the agentic RAG pipeline with thread-safe memory."""
    app = build_agent_graph()
    inputs = {"query": query}
    config = {"configurable": {"thread_id": thread_id}}
    result = app.invoke(inputs, config=config)
    
    answer = result["generation"]
    contexts = result.get("contexts", [])
    
    if return_contexts:
        return answer, contexts
    return answer

async def run_pipeline_async(
    query: str,
    return_contexts: bool = False,
    thread_id: str = "default_thread",
) -> str | tuple[str, list[str]]:
    """Asynchronously run the agentic RAG pipeline with thread-safe memory."""
    app = build_agent_graph()
    inputs = {"query": query}
    config = {"configurable": {"thread_id": thread_id}}
    result = await app.ainvoke(inputs, config=config)
    
    answer = result["generation"]
    contexts = result.get("contexts", [])
    
    if return_contexts:
        return answer, contexts
    return answer
