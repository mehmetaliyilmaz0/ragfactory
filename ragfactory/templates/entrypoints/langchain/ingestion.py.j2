def ingest(source_path: str) -> None:
    """Load documents from source_path, chunk, embed, and store.

    Args:
        source_path: Path to a file or directory to ingest.
    """
    from langchain_community.document_loaders import DirectoryLoader, TextLoader

    path = Path(source_path)
    if path.is_dir():
        loader = DirectoryLoader(str(path), glob="{{ ingestion.sources[0].glob if ingestion.sources else '**/*' }}")
    else:
        loader = TextLoader(str(path))

    raw_docs = loader.load()
    splitter  = build_chunking()
    chunks    = splitter.split_documents(raw_docs)

    embedder    = build_embedding()
    vectorstore = build_vectordb(embedder)
    vectorstore.add_documents(chunks)
    print(f"Ingested {len(chunks)} chunks from {source_path!r}")


