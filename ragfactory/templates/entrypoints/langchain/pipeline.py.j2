def _format_docs(docs: list, max_sources: int = {{ post_retrieval.context_assembly.max_sources }}) -> str:
    return "\n---\n".join(doc.page_content for doc in docs[:max_sources])


# ─── Pipeline ─────────────────────────────────────────────────────────────────


def run_pipeline(query: str) -> str:
    """Run the full {{ pipeline_name }} RAG pipeline.

    Args:
        query: The user question to answer.

    Returns:
        The generated answer string.
    """
    embedder    = build_embedding()
    vectorstore = build_vectordb(embedder)
    retriever   = build_retrieval(vectorstore)
{% if stages.reranker is defined and stages.reranker %}
    retriever   = build_reranker(retriever)
{% endif %}
    llm         = build_llm()

{% if pre_retrieval.query_rewriting is not none and pre_retrieval.query_rewriting.enabled %}
    # ── Query Rewriting ({{ pre_retrieval.query_rewriting.strategy }},
    #    {{ pre_retrieval.query_rewriting.num_rewrites }} variants) ────────────
    from langchain_core.prompts import PromptTemplate
    from langchain_core.output_parsers import CommaSeparatedListOutputParser
    _rewrite_prompt = PromptTemplate.from_template(
        "Generate {{ pre_retrieval.query_rewriting.num_rewrites }} concise search "
        "query variants for: {question}\nOutput as a comma-separated list."
    )
    _rewrite_chain = _rewrite_prompt | llm | CommaSeparatedListOutputParser()
    _variants: list[str] = [query] + list(_rewrite_chain.invoke({"question": query}))
    _seen: set[str] = set()
    _all_docs: list = []
    for _q in _variants:
        for _doc in retriever.invoke(_q):
            if _doc.page_content not in _seen:
                _seen.add(_doc.page_content)
                _all_docs.append(_doc)
    docs = _all_docs
{% elif pre_retrieval.hyde is not none and pre_retrieval.hyde.enabled %}
    # ── HyDE — Hypothetical Document Embeddings ───────────────────────────────
    _hyde_prompt = ChatPromptTemplate.from_messages([
        ("system", "Write a short hypothetical document that would answer this question."),
        ("human", "{question}"),
    ])
    _hypothesis = (_hyde_prompt | llm | StrOutputParser()).invoke({"question": query})
    docs        = retriever.invoke(_hypothesis)
{% else %}
    docs = retriever.invoke(query)
{% endif %}

    # ── Context Assembly ──────────────────────────────────────────────────────
    context = _format_docs(docs)

    # ── Generation ────────────────────────────────────────────────────────────
    _prompt = ChatPromptTemplate.from_template(_PROMPT_TEMPLATE)
    _chain  = _prompt | llm | StrOutputParser()
    return _chain.invoke({"context": context, "question": query})
