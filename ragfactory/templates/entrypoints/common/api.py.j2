"""FastAPI server for serving {{ pipeline_name }} RAG queries.

Generated by ragfactory.
"""
from __future__ import annotations

import os
from fastapi import FastAPI, HTTPException
from pydantic import BaseModel

from pipeline import run_pipeline

app = FastAPI(
    title="{{ pipeline_name }} API",
    description="FastAPI service serving RAG pipeline queries.",
    version="1.0",
)


class QueryRequest(BaseModel):
    query: str
    return_contexts: bool = False


class QueryResponse(BaseModel):
    answer: str
    contexts: list[str] | None = None


@app.post("/query", response_model=QueryResponse)
def query_rag(request: QueryRequest) -> QueryResponse:
    try:
        res = run_pipeline(request.query, return_contexts=request.return_contexts)
        if isinstance(res, tuple):
            return QueryResponse(answer=res[0], contexts=res[1])
        return QueryResponse(answer=res)
    except Exception as e:
        raise HTTPException(status_code=500, detail=str(e)) from e


if __name__ == "__main__":
    import uvicorn
    port = int(os.getenv("PORT", "8000"))
    uvicorn.run("api:app", host="0.0.0.0", port=port, reload=True)
