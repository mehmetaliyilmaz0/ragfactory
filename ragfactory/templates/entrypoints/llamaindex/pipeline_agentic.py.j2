# ─── Events ───────────────────────────────────────────────────────────────────
class RetrievalEvent(Event):
    query: str
    contexts: List[str]

# ─── Workflow ─────────────────────────────────────────────────────────────────
class RAGWorkflow(Workflow):
    @step
    async def retrieve(self, ev: StartEvent) -> RetrievalEvent:
        print("--- RETRIEVING (WORKFLOW) ---")
        embed_model = build_embedding()
        vectorstore = build_vectordb(embed_model)
        retriever = build_retrieval(vectorstore)
        
        nodes = retriever.retrieve(ev.query)
        contexts = [node.node.get_content() for node in nodes]
        
        return RetrievalEvent(query=ev.query, contexts=contexts)

    @step
    async def generate(self, ev: RetrievalEvent) -> StopEvent:
        print("--- GENERATING (WORKFLOW) ---")
        llm = build_llm()
        context_str = "\n---\n".join(ev.contexts)
        
        prompt = _PROMPT_TEMPLATE.format(context=context_str, question=ev.query)
        response = await llm.acomplete(prompt)
        
        return StopEvent(result={
            "answer": str(response),
            "contexts": ev.contexts
        })

# ─── Pipeline Entrypoints ─────────────────────────────────────────────────────
async def run_pipeline_async(query: str, return_contexts: bool = False) -> str | tuple[str, list[str]]:
    """Asynchronously run the LlamaIndex Workflow RAG pipeline."""
    Settings.embed_model = build_embedding()
    Settings.llm = build_llm()
    
    workflow = RAGWorkflow(timeout=60.0, verbose=True)
    result = await workflow.run(query=query)
    
    answer = result["answer"]
    contexts = result["contexts"]
    
    if return_contexts:
        return answer, contexts
    return answer


def run_pipeline(query: str, return_contexts: bool = False) -> str | tuple[str, list[str]]:
    """Synchronously run the LlamaIndex Workflow RAG pipeline."""
    import asyncio
    try:
        loop = asyncio.get_event_loop()
    except RuntimeError:
        loop = asyncio.new_event_loop()
        asyncio.set_event_loop(loop)
        
    result = loop.run_until_complete(run_pipeline_async(query, return_contexts=True))
    answer, contexts = result
    
    if return_contexts:
        return answer, contexts
    return answer
