# ─── RAGFactory Environment Variables ────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
#
# Only the variables relevant to your chosen components are required.
# ragfactory validate --config pipeline.yaml will tell you exactly
# which variables are needed for your specific configuration.

# ─── Embedding Models ─────────────────────────────────────────────────────────

# OpenAI  (embedding: openai, llm: openai)
OPENAI_API_KEY=sk-...

# Anthropic  (llm: anthropic, chunking: contextual default model)
ANTHROPIC_API_KEY=sk-ant-...

# Cohere  (embedding: cohere, llm: cohere_llm, reranker: cohere)
COHERE_API_KEY=...

# Voyage AI  (embedding: voyage)
VOYAGE_API_KEY=pa-...

# Google AI  (embedding: gemini, llm: gemini)
GOOGLE_API_KEY=...

# Jina AI  (embedding: jina)
JINA_API_KEY=...

# ─── Vector Databases ─────────────────────────────────────────────────────────

# Qdrant  (vectordb: qdrant)
# Optional for local deployment, required for Qdrant Cloud
QDRANT_API_KEY=
QDRANT_URL=http://localhost:6333

# Pinecone  (vectordb: pinecone)
PINECONE_API_KEY=pcsk_...

# Weaviate  (vectordb: weaviate)
# Optional for local deployment, required for Weaviate Cloud
WEAVIATE_API_KEY=
WEAVIATE_URL=http://localhost:8080

# Milvus / Zilliz Cloud  (vectordb: milvus)
# Optional for local Milvus, required for Zilliz Cloud
MILVUS_TOKEN=

# pgvector  (vectordb: pgvector)
PGVECTOR_CONNECTION_STRING=postgresql://user:password@localhost:5432/ragfactory

# ─── Web Search (CRAG fallback) ───────────────────────────────────────────────

# Tavily  (generation.advanced.crag.web_search_provider: tavily)
TAVILY_API_KEY=tvly-...

# Serper  (generation.advanced.crag.web_search_provider: serper)
SERPER_API_KEY=...

# ─── Document Parsers ─────────────────────────────────────────────────────────

# Azure Document Intelligence  (ingestion.parser: azure_doc_intelligence)
AZURE_DOC_INTELLIGENCE_KEY=...
AZURE_DOC_INTELLIGENCE_ENDPOINT=https://<resource>.cognitiveservices.azure.com/
