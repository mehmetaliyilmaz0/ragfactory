def load_test_cases() -> list[dict[str, str]]:
    # Default sample test cases if no dataset file is found
    default_cases = [
        {
            "question": "What is the name of this pipeline?",
            "ground_truth": "{{ pipeline_name }}"
        }
    ]
    
    dataset_path = Path("eval_dataset.json")
    if dataset_path.exists():
        try:
            with open(dataset_path, "r", encoding="utf-8") as f:
                return json.load(f)
        except Exception as e:
            print(f"Error loading eval_dataset.json: {e}. Using defaults.")
    
    return default_cases

def run_evaluation() -> None:
    print("Loading test cases...")
    test_cases = load_test_cases()
    
    print(f"Running pipeline to generate answers for {len(test_cases)} cases...")
    results = []
    for case in test_cases:
        question = case["question"]
        print(f"Querying: {question}")
        answer, contexts = run_pipeline(question, return_contexts=True)
        
        results.append({
            "question": question,
            "answer": answer,
            "contexts": contexts,
            "ground_truth": case.get("ground_truth", "")
        })

    passed = True
    
    {% if evaluation.framework == "ragas" or evaluation.framework == "both" %}
    print("\n--- Running Ragas Evaluation ---")
    dataset_dict = {
        "question": [r["question"] for r in results],
        "answer": [r["answer"] for r in results],
        "contexts": [r["contexts"] for r in results],
        "ground_truth": [r["ground_truth"] for r in results],
    }
    dataset = Dataset.from_dict(dataset_dict)
    
    metrics = [
        {% for metric in evaluation.metrics %}
        {% if metric == "faithfulness" %}
        faithfulness,
        {% elif metric == "answer_relevancy" %}
        answer_relevancy,
        {% elif metric == "context_precision" %}
        context_precision,
        {% endif %}
        {% endfor %}
    ]
    
    # Run Ragas evaluation
    eval_result = evaluate(
        dataset=dataset,
        metrics=metrics,
    )
    print("Ragas Scores:")
    print(eval_result)
    
    # Check threshold
    for metric_name, score in eval_result.items():
        if score < {{ evaluation.pass_threshold }}:
            print(f"FAIL: Metric '{metric_name}' score {score:.2f} is below pass_threshold {{ evaluation.pass_threshold }}")
            passed = False
    {% endif %}

    {% if evaluation.framework == "deepeval" or evaluation.framework == "both" %}
    print("\n--- Running DeepEval Evaluation ---")
    deepeval_test_cases = []
    for r in results:
        deepeval_test_cases.append(LLMTestCase(
            input=r["question"],
            actual_output=r["answer"],
            expected_output=r["ground_truth"],
            retrieval_context=r["contexts"]
        ))
        
    metrics = [
        {% for metric in evaluation.metrics %}
        {% if metric == "faithfulness" %}
        FaithfulnessMetric(threshold={{ evaluation.pass_threshold }}),
        {% elif metric == "answer_relevancy" %}
        AnswerRelevancyMetric(threshold={{ evaluation.pass_threshold }}),
        {% elif metric == "context_precision" %}
        ContextPrecisionMetric(threshold={{ evaluation.pass_threshold }}),
        {% endif %}
        {% endfor %}
    ]
    
    for case in deepeval_test_cases:
        for metric in metrics:
            metric.measure(case)
            print(f"DeepEval Metric '{metric.__class__.__name__}' score: {metric.score:.2f} (Passed: {metric.is_successful()})")
            if not metric.is_successful():
                passed = False
    {% endif %}

    if passed:
        print("\nSUCCESS: All evaluation metrics passed threshold verification.")
        sys.exit(0)
    else:
        print("\nFAILURE: Evaluation metrics failed threshold verification.")
        sys.exit(1)

if __name__ == "__main__":
    run_evaluation()
