[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[project]
name = "{{ pipeline_name }}"
version = "0.1.0"
description = "RAG pipeline generated by ragfactory"
readme = "README.md"
requires-python = ">={{ python_version }}"
license = {text = "Apache-2.0"}
dependencies = [
{% for dep in dependencies %}
    "{{ dep }}",
{% endfor %}
]

[project.scripts]
{{ pipeline_name | replace("-", "_") }} = "pipeline:run_pipeline"

[tool.hatch.build.targets.wheel]
packages = ["."]

[tool.pytest.ini_options]
testpaths = ["tests"]

[tool.ruff.lint]
select = ["E", "F", "I"]
