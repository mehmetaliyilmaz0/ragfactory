# ── Retrieval: Hybrid RRF (BM25 + Dense, Reciprocal Rank Fusion) ──────────
{% if framework == "langchain" %}
from langchain.retrievers import EnsembleRetriever
from langchain_community.retrievers import BM25Retriever
{% elif framework == "llamaindex" %}
from llama_index.core.retrievers import QueryFusionRetriever, VectorIndexRetriever
from llama_index.core import VectorStoreIndex, StorageContext, Settings
{% endif %}

def build_retrieval(vectorstore: Any) -> Any:
{% if framework == "langchain" %}
    dense_retriever = vectorstore.as_retriever(search_kwargs={"k": {{ retrieval.top_k }}})
    # BM25 sparse retriever.
    # IMPORTANT: Populate during ingestion by calling:
    #   bm25_retriever = BM25Retriever.from_documents(docs, k={{ retrieval.top_k }})
    # and serializing with pickle. Load that serialized index here.
    # Until populated, the BM25 side returns no results; only dense results are returned.
    bm25_retriever = BM25Retriever.from_texts([], k={{ retrieval.top_k }})
    return EnsembleRetriever(
        retrievers=[bm25_retriever, dense_retriever],
        weights=[0.5, 0.5],
        # RRF constant k={{ retrieval.rrf_k }}
    )
{% elif framework == "llamaindex" %}
    # NOTE: True hybrid search (dense + sparse) requires a vector store with native
    # sparse vector support (e.g., Qdrant with sparse vectors). QueryFusionRetriever
    # here performs query expansion (num_queries=1) on a dense retriever.
    # For native hybrid search, configure your vector store accordingly.
    storage_context = StorageContext.from_defaults(vector_store=vectorstore)
    index = VectorStoreIndex.from_vector_store(vectorstore, storage_context=storage_context)
    dense_retriever = VectorIndexRetriever(index=index, similarity_top_k={{ retrieval.top_k }})
    return QueryFusionRetriever(
        [dense_retriever],
        llm=Settings.llm,
        num_queries=1,
        mode="reciprocal_rerank",
        similarity_top_k={{ retrieval.top_k }},
    )
{% endif %}
